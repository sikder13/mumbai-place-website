# Copy this file to .env.local and fill in the values.
# .env.local is git-ignored. Do not commit real keys.

# Resend API key for the contact form (https://resend.com/api-keys).
RESEND_API_KEY=

# Where contact form submissions are delivered.
CONTACT_TO=mumbaiplace99@gmail.com

# "From" address used by Resend.
# Until a sending domain is verified in Resend, use onboarding@resend.dev.
# Once you verify mumbaiplacenyc.com in Resend, switch this to
#   "Mumbai Place <noreply@mumbaiplacenyc.com>"
CONTACT_FROM="Mumbai Place Website <onboarding@resend.dev>"
